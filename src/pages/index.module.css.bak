/* Hero Banner */
.heroBanner {
  position: relative;
  overflow: hidden;
  padding: 2rem 1rem;
  text-align: center;
  background: linear-gradient(135deg, #0a0a0a 0%, #0f0f1e 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Background Blob Effects */
.backgroundEffects {
  position: fixed;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 1;
}

.blob1 {
  position: absolute;
  top: 20%;
  left: 15%;
  width: 400px;
  height: 400px;
  background: rgba(34, 197, 94, 0.1);
  border-radius: 50%;
  filter: blur(100px);
  animation: pulse-slow 8s ease-in-out infinite;
}

.blob2 {
  position: absolute;
  bottom: 20%;
  right: 15%;
  width: 350px;
  height: 350px;
  background: rgba(34, 197, 94, 0.15);
  border-radius: 50%;
  filter: blur(100px);
  animation: float 12s ease-in-out infinite;
}

/* Hero Content */
.heroContent {
  position: relative;
  z-index: 10;
  max-width: 56rem;
  margin: 0 auto;
  padding: 1rem;
}

/* Hero Title */
.heroTitle {
  font-size: clamp(1.75rem, 7vw, 3.5rem);
  font-weight: 700;
  line-height: 1.2;
  color: #ffffff;
  margin-bottom: 1.5rem;
  letter-spacing: -0.02em;
  text-shadow: 0 0 40px rgba(34, 197, 94, 0.3);
}

.gradientText {
  display: block;
  background: linear-gradient(to right, #22C55E, #4ADE80, #22C55E);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 20px rgba(34, 197, 94, 0.8));
  animation: pulse-slow 8s ease-in-out infinite;
  margin-top: 0.5rem;
}

/* Hero Subtitle */
.heroSubtitle {
  font-size: clamp(0.9rem, 2vw, 1.25rem);
  line-height: 1.8;
  color: #a3a3a3;
  margin-bottom: 2rem;
  max-width: 48rem;
  margin-left: auto;
  margin-right: auto;
}

/* Button Group */
.buttonGroup {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
  align-items: center;
}

/* Primary Button */
.primaryButton {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.875rem 1.5rem;
  font-size: clamp(0.95rem, 1.5vw, 1.125rem);
  font-weight: 600;
  color: #ffffff;
  background: #22C55E;
  border: none;
  border-radius: 0.5rem;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 0 30px rgba(34, 197, 94, 0.6), 0 0 60px rgba(34, 197, 94, 0.3);
  text-decoration: none !important;
  white-space: nowrap;
}

.primaryButton::before {
  content: '';
  position: absolute;
  inset: -4px;
  background: rgba(34, 197, 94, 0.4);
  border-radius: 0.5rem;
  filter: blur(32px);
  z-index: -1;
  pointer-events: none;
}

.primaryButton:hover {
  background: #16a34a;
  transform: scale(1.05);
  box-shadow: 0 0 40px rgba(34, 197, 94, 0.8), 0 0 80px rgba(34, 197, 94, 0.4);
}

.primaryButton:active {
  transform: scale(0.98);
}

/* Secondary Button */
.secondaryButton {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.875rem 1.5rem;
  font-size: clamp(0.95rem, 1.5vw, 1.125rem);
  font-weight: 600;
  color: #22C55E;
  background: transparent;
  border: 2px solid #22C55E;
  border-radius: 0.5rem;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none !important;
  white-space: nowrap;
}

.secondaryButton:hover {
  background: rgba(34, 197, 94, 0.1);
  box-shadow: 0 0 20px rgba(34, 197, 94, 0.5);
}

.secondaryButton:active {
  transform: scale(0.98);
}

/* Button Icon */
.buttonIcon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

/* Animations */
@keyframes pulse-slow {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.8;
  }
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-10px);
  }
}

/* 平板设备 */
@media (max-width: 1024px) {
  .blob1 {
    width: 300px;
    height: 300px;
    top: 15%;
    left: 10%;
  }

  .blob2 {
    width: 280px;
    height: 280px;
    bottom: 15%;
    right: 10%;
  }

  .heroBanner {
    padding: 2rem 0.75rem;
  }

  .heroTitle {
    margin-bottom: 1rem;
  }

  .heroSubtitle {
    margin-bottom: 1.5rem;
  }

  .buttonGroup {
    gap: 0.75rem;
  }
}

/* 手机设备 */
@media (max-width: 768px) {
  .heroBanner {
    min-height: 80vh;
    padding: 1.5rem 0.5rem;
  }

  .blob1 {
    width: 200px;
    height: 200px;
    top: 10%;
    left: 5%;
    filter: blur(80px);
  }

  .blob2 {
    width: 180px;
    height: 180px;
    bottom: 10%;
    right: 5%;
    filter: blur(80px);
  }

  .heroContent {
    padding: 0.5rem;
  }

  .heroTitle {
    font-size: clamp(1.5rem, 6vw, 2.5rem);
    margin-bottom: 0.75rem;
    text-shadow: 0 0 30px rgba(34, 197, 94, 0.2);
  }

  .gradientText {
    margin-top: 0.25rem;
  }

  .heroSubtitle {
    font-size: clamp(0.85rem, 1.8vw, 1rem);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .buttonGroup {
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }

  .primaryButton,
  .secondaryButton {
    width: 100%;
    max-width: 300px;
    padding: 0.75rem 1.25rem;
    font-size: 1rem;
  }

  .primaryButton::before {
    inset: -3px;
  }
}

/* 小手机设备 */
@media (max-width: 480px) {
  .heroBanner {
    min-height: 100vh;
    padding: 1rem 0.25rem;
  }

  .blob1 {
    width: 150px;
    height: 150px;
    top: 5%;
    left: 0%;
    filter: blur(70px);
  }

  .blob2 {
    width: 130px;
    height: 130px;
    bottom: 5%;
    right: 0%;
    filter: blur(70px);
  }

  .heroTitle {
    font-size: clamp(1.25rem, 5vw, 2rem);
    margin-bottom: 0.5rem;
  }

  .heroSubtitle {
    font-size: clamp(0.8rem, 1.6vw, 0.95rem);
    margin-bottom: 1rem;
  }

  .buttonGroup {
    gap: 0.5rem;
  }

  .primaryButton,
  .secondaryButton {
    padding: 0.65rem 1rem;
    font-size: 0.9rem;
  }

  .buttonIcon {
    width: 16px;
    height: 16px;
  }

/* Footer深色主题 */
.theme-layout-footer,
.footer--dark {
  background-color: #0a0a0a !important;
  border-top: 1px solid #262626 !important;
}

.footer--dark .footer__bottom {
  background-color: #0a0a0a !important;
}

.footer__copyright {
  color: #ffffff !important;
}

.footer a {
  color: #a855f7 !important;
}

.footer a:hover {
  color: #c084fc !important;
}